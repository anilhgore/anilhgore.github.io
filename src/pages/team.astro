---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
import authorsData from '../data/authors.json';

const piMembers = authorsData
	.filter(m => m.isTeam && !m.alumni && m.role === 'Principal Investigator')
	.sort((a, b) => (a.sortOrder || 99) - (b.sortOrder || 99));

const currentStudents = authorsData
	.filter(m => m.isTeam && !m.alumni && m.role !== 'Principal Investigator' && m.role !== 'Dissertation Student')
	.sort((a, b) => (a.sortOrder || 99) - (b.sortOrder || 99));

const alumni = authorsData
	.filter(m => m.isTeam && m.alumni)
	.sort((a, b) => (a.sortOrder || 99) - (b.sortOrder || 99));

const dissertationStudents = authorsData
	.filter(m => m.isTeam && !m.alumni && m.role === 'Dissertation Student')
	.sort((a, b) => (a.sortOrder || 99) - (b.sortOrder || 99));

const collaborators = authorsData
	.filter(m => !m.isTeam)
	.sort((a, b) => (a.sortOrder || 99) - (b.sortOrder || 99));
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Team | ${SITE_TITLE}`} description="Research Team & Collaborators" />
		<style>
			.team-hero {
				text-align: center;
				margin-bottom: 3rem;
				padding: 2rem 0;
			}
			.team-hero h1 {
				font-family: var(--font-serif);
				font-size: 3.2rem;
				margin: 0 0 1rem 0;
				letter-spacing: -0.02em;
			}
			.team-hero p {
				font-size: 1.15rem;
				color: var(--color-text-muted);
				max-width: 700px;
				margin: 0 auto;
				line-height: 1.7;
			}
			.section-subtitle {
				font-size: 0.85rem;
				text-transform: uppercase;
				letter-spacing: 0.1em;
				color: var(--color-text-muted);
				margin-bottom: 0.5rem;
				font-family: var(--font-sans);
			}
			.pi-card {
				display: flex;
				gap: 2.5rem;
				align-items: center;
				padding: 2.5rem;
				background: var(--color-bg-offset);
				border: 1px solid var(--color-border);
				border-radius: 16px;
				margin-bottom: 3rem;
				transition: border-color 0.3s ease;
			}
			.pi-card:hover { border-color: var(--color-accent); }
			.pi-card img {
				width: 160px;
				height: 160px;
				border-radius: 50%;
				object-fit: cover;
				border: 4px solid var(--color-accent-light);
				flex-shrink: 0;
			}
			.pi-info h3 {
				font-size: 1.8rem;
				margin: 0 0 0.25rem 0;
				color: var(--color-text-main);
			}
			.pi-info .pi-title {
				color: var(--color-accent);
				font-weight: 600;
				font-size: 1.05rem;
				display: block;
				margin-bottom: 0.75rem;
			}
			.pi-info p {
				line-height: 1.7;
				color: var(--color-text-muted);
				margin: 0;
			}
			.collab-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
				gap: 1.5rem;
				margin-top: 1.5rem;
			}
			.collab-card {
				display: flex;
				gap: 1rem;
				align-items: center;
				padding: 1.25rem;
				background: var(--color-bg-offset);
				border: 1px solid var(--color-border);
				border-radius: 12px;
				cursor: pointer;
				transition: all 0.2s ease;
			}
			.collab-card:hover {
				border-color: var(--color-accent);
				transform: translateY(-2px);
				box-shadow: var(--shadow-md);
			}
			.collab-card img {
				width: 48px;
				height: 48px;
				border-radius: 50%;
				object-fit: cover;
				flex-shrink: 0;
			}
			.collab-info .collab-name {
				font-weight: 700;
				font-size: 0.95rem;
				color: var(--color-text-main);
				display: block;
			}
			.collab-info .collab-affil {
				font-size: 0.8rem;
				color: var(--color-text-muted);
			}
			@media (max-width: 768px) {
				.pi-card {
					flex-direction: column;
					text-align: center;
					padding: 2rem 1.5rem;
				}
				.pi-card img { width: 120px; height: 120px; }
				.team-hero h1 { font-size: 2.5rem; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="team-hero">
				<h1>Research Team</h1>
				<p>Meet the researchers advancing analytical chemistry and sustainable nanotechnology at UKA Tarsadia University.</p>
			</div>

			{piMembers.map((member) => (
				<div class="pi-card author-modal-trigger" data-member={JSON.stringify(member)}>
					{member.avatar && <img src={member.avatar} alt={member.name} />}
					<div class="pi-info">
						<h3>{member.name}</h3>
						<span class="pi-title">{member.title}</span>
						<p>{member.bio}</p>
					</div>
				</div>
			))}
			
			<h2>PhD Students</h2>
			<div class="grid-3">
				{currentStudents.length > 0 ? currentStudents.map((member) => (
					<div class="team-card interactive-card author-modal-trigger" data-member={JSON.stringify(member)}>
						{member.avatar ? (
							<img 
								src={member.avatar} 
								alt={member.name} 
								class="team-avatar"
							/>
						) : (
							<img src="https://ui-avatars.com/api/?name=NA&background=ccc&color=fff&size=200" alt="Placeholder" class="team-avatar" />
						)}
						<span class="team-name">{member.name}</span>
						<span class="team-role">{member.title}</span>
						<span style="font-size: 0.85rem; color: var(--color-text-muted); display: block; margin-top: 4px;">{member.role}</span>
					</div>
				)) : <p>No current students listed.</p>}
			</div>

			{alumni.length > 0 && (
				<>
					<h2>Alumni</h2>
					<div class="grid-3">
						{alumni.map((member) => (
							<div class="team-card interactive-card author-modal-trigger" data-member={JSON.stringify(member)}>
								{member.avatar && <img src={member.avatar} alt={member.name} class="team-avatar" />}
								<span class="team-name">{member.name}</span>
								<span class="team-role">{member.title}</span>
							</div>
						))}
					</div>
				</>
			)}

			{dissertationStudents.length > 0 && (
				<>
					<h2>Dissertation Students</h2>
					<div class="grid-3">
						{dissertationStudents.map((member) => (
							<div class="team-card interactive-card author-modal-trigger" data-member={JSON.stringify(member)}>
								{member.avatar ? (
									<img src={member.avatar} alt={member.name} class="team-avatar" />
								) : (
									<img src="https://ui-avatars.com/api/?name=NA&background=ccc&color=fff&size=200" alt="Placeholder" class="team-avatar" />
								)}
								<span class="team-name">{member.name}</span>
								<span class="team-role">{member.title}</span>
								<span style="font-size: 0.85rem; color: var(--color-text-muted); display: block; margin-top: 4px;">{member.role}</span>
							</div>
						))}
					</div>
				</>
			)}

			{collaborators.length > 0 && (
				<>
					<h2>Research Collaborators</h2>
					<p style="color: var(--color-text-muted); margin-bottom: 0.5rem;">National and international research collaborators across South Korea, Japan, and India.</p>
					<div class="collab-grid">
						{collaborators.map((member) => (
							<div class="collab-card author-modal-trigger" data-member={JSON.stringify(member)}>
								{member.avatar && <img src={member.avatar} alt={member.name} />}
								<div class="collab-info">
									<span class="collab-name">{member.name}</span>
									<span class="collab-affil">{member.title}</span>
								</div>
							</div>
						))}
					</div>
				</>
			)}
		</main>

		<Footer />
	</body>
</html>